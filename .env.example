# 复制此文件为 .env 后填入真实值; .env 不入 git
# docker-compose 会自动读取同目录的 .env

# Claude API key — 留空走 mock 模式 (前端依然完整可演示)
ANTHROPIC_API_KEY=

# AI 模型 (默认 claude-sonnet-4-6)
BWS_AI_MODEL=claude-sonnet-4-6

# 默认汇率 1 RMB = X IDR
BWS_DEFAULT_RATE=2300

# Postgres 密码 (仅在启用 --profile postgres 时使用)
POSTGRES_PASSWORD=bws_change_me_in_prod

# 初始超级管理员账号 + 密码 (v0.8 起强制启用用户系统)
# - 这是首次启动时自动创建的 super_admin 账号
# - 首次登录后请立即在 "账号管理" 里改密码
# - 留空也会用 admin/admin123 兜底
BWS_AUTH_USERNAME=admin
BWS_AUTH_PASSWORD=admin123

# 用于签名登录 cookie 的密钥(随机串)
BWS_AUTH_SECRET=change-me-to-a-random-string
